# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres  # Transaction Pooler for runtime
DIRECT_DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres  # Direct for migrations

# ── Security ──────────────────────────────────────────────────────────────────
APP_ENV=development
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
ADMIN_API_KEY=
VERIFY_TOKEN=

# ── Instagram ─────────────────────────────────────────────────────────────────
PAGE_ACCESS_TOKEN=
BOT_INSTAGRAM_ID=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Integrations ──────────────────────────────────────────────────────────────
REDIS_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
WHATSAPP_LINK=

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_CLOUD_VERIFY_TOKEN=
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_DEFAULT_CLIENT_ID=
# Optional mapping from WhatsApp Cloud phone_number_id to internal client_id.
# Falls back to WHATSAPP_CLOUD_DEFAULT_CLIENT_ID if not set.
WHATSAPP_CLOUD_CLIENT_MAP=
WHATSAPP_CLOUD_API_VERSION=v25.0
# Optional test-mode mapping from webhook wa_id to Meta API Setup allowed recipient input.
WHATSAPP_CLOUD_RECIPIENT_OVERRIDES=
WHATSAPP_CLOUD_OUTBOX_TTL_SECONDS=604800
WHATSAPP_CLOUD_OUTBOX_MAX_ATTEMPTS=5
WHATSAPP_CLOUD_DEBOUNCE_SECONDS=3
WHATSAPP_CLOUD_LOCK_TTL_SECONDS=120
